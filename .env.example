# intervals.icu Zugangsdaten
# API Key: intervals.icu → Settings → Developer → API Key
INTERVALS_API_KEY=dein_api_key_hier

# Athlete ID: steht in der URL nach dem Login
# https://intervals.icu/athlete/XXXXXXX  ← diese ID
INTERVALS_ATHLETE_ID=iXXXXXX

# Strava API Zugangsdaten
# App registrieren: https://www.strava.com/settings/api
# Client ID und Secret findest du dort direkt nach der Registrierung
STRAVA_CLIENT_ID=deine_client_id
STRAVA_CLIENT_SECRET=dein_client_secret

# Refresh Token: einmalig über OAuth holen
# Anleitung: https://developers.strava.com/docs/getting-started/
# Benötigte Scopes: read,activity:read,profile:read_all
# Der Refresh Token läuft nicht ab – nur der Access Token (alle 6h, wird automatisch erneuert)
STRAVA_REFRESH_TOKEN=dein_refresh_token

# Kommagetrennte Strava Gear-IDs deiner Fahrräder
# IDs findest du in der Strava URL: strava.com/bikes/XXXXXXXX
# oder via GET /gear/{id} mit einem gültigen Token
STRAVA_BIKE_IDS=15874165,17420238

# Optionaler Datenbankpfad (Standard: ./veloform.db)
# DB_PATH=/opt/veloform/veloform.db
